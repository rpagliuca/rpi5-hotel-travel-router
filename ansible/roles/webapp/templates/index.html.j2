<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ ap_ssid | default('Travel Router') }} — Config</title>
<style>
  :root { color-scheme: light dark; --bg:#f4f5f7; --card:#fff; --fg:#1a1a1a; --muted:#666; --border:#e2e4e8; --accent:#2563eb; --ok:#16a34a; --warn:#d97706; --danger:#dc2626; }
  @media (prefers-color-scheme: dark) { :root { --bg:#0f1115; --card:#1a1d24; --fg:#e8eaed; --muted:#9aa0a8; --border:#2a2e37; --accent:#3b82f6; } }
  * { box-sizing:border-box; }
  body { margin:0; font-family:system-ui,-apple-system,Segoe UI,Roboto,sans-serif; background:var(--bg); color:var(--fg); line-height:1.45; }
  .wrap { max-width:560px; margin:0 auto; padding:16px; }
  h1 { font-size:1.3rem; margin:8px 0 4px; }
  .sub { color:var(--muted); font-size:.85rem; margin-bottom:16px; }
  .card { background:var(--card); border:1px solid var(--border); border-radius:14px; padding:16px; margin-bottom:14px; }
  .card h2 { font-size:.95rem; margin:0 0 12px; text-transform:uppercase; letter-spacing:.04em; color:var(--muted); }
  .row { display:flex; justify-content:space-between; gap:12px; padding:4px 0; font-size:.92rem; }
  .row .k { color:var(--muted); } .row .v { font-weight:600; text-align:right; word-break:break-word; }
  .pill { display:inline-block; padding:2px 10px; border-radius:999px; font-size:.8rem; font-weight:600; }
  .pill.ok { background:color-mix(in srgb,var(--ok) 18%,transparent); color:var(--ok); }
  .pill.off { background:color-mix(in srgb,var(--danger) 18%,transparent); color:var(--danger); }
  .pill.warn{ background:color-mix(in srgb,var(--warn) 18%,transparent); color:var(--warn); }
  button { font:inherit; font-weight:600; border:0; border-radius:10px; padding:11px 14px; cursor:pointer; background:var(--accent); color:#fff; }
  button.sec { background:transparent; border:1px solid var(--border); color:var(--fg); }
  button.danger { background:var(--danger); }
  button:disabled { opacity:.5; cursor:default; }
  .btns { display:flex; gap:10px; flex-wrap:wrap; }
  .btns > * { flex:1; min-width:120px; }
  input { font:inherit; width:100%; padding:11px; border:1px solid var(--border); border-radius:10px; background:var(--bg); color:var(--fg); margin-top:8px; }
  label { font-size:.85rem; color:var(--muted); }
  .net { display:flex; align-items:center; gap:10px; padding:10px; border:1px solid var(--border); border-radius:10px; margin-top:8px; cursor:pointer; }
  .net:hover { border-color:var(--accent); }
  .net .name { flex:1; font-weight:600; }
  .net .meta { font-size:.78rem; color:var(--muted); }
  .toast { position:fixed; left:50%; bottom:20px; transform:translateX(-50%); background:var(--fg); color:var(--bg); padding:10px 16px; border-radius:10px; font-size:.88rem; opacity:0; transition:opacity .2s; pointer-events:none; max-width:90%; }
  .toast.show { opacity:.95; }
  .spin { display:inline-block; width:14px; height:14px; border:2px solid var(--muted); border-top-color:transparent; border-radius:50%; animation:s .7s linear infinite; vertical-align:-2px; }
  @keyframes s { to { transform:rotate(360deg); } }
  .hint { font-size:.8rem; color:var(--muted); margin-top:8px; }
</style>
</head>
<body>
<div class="wrap">
  <h1>🧳 {{ ap_ssid | default('Travel Router') }}</h1>
  <div class="sub">Configuração — acesse por <code>http://{{ ap_ip | default('192.168.88.1') }}</code></div>

  <div class="card">
    <h2>Status <span id="st-refresh" style="float:right;font-weight:400;text-transform:none"></span></h2>
    <div class="row"><span class="k">Modo</span><span class="v"><span id="s-mode" class="pill warn">—</span></span></div>
    <div class="row"><span class="k">Wi-Fi do hotel (uplink)</span><span class="v" id="s-uplink">—</span></div>
    <div class="row"><span class="k">Internet</span><span class="v" id="s-inet">—</span></div>
    <div class="row"><span class="k">Tailscale</span><span class="v" id="s-ts">—</span></div>
    <div class="row"><span class="k">Saída (exit node)</span><span class="v" id="s-exit">—</span></div>
    <div class="row"><span class="k">Dispositivos no AP</span><span class="v" id="s-clients">—</span></div>
  </div>

  <div class="card">
    <h2>Saída da internet</h2>
    <div class="btns">
      <button id="b-secure" onclick="setMode('secure')">🔒 Seguro (via Tailscale)</button>
      <button id="b-portal" class="sec" onclick="setMode('portal')">🌐 Portal (direto p/ login)</button>
    </div>
    <div class="hint">Use <b>Portal</b> para abrir o login do hotel no navegador; volte para <b>Seguro</b> depois.</div>
  </div>

  <div class="card">
    <h2>Conectar no Wi-Fi do hotel</h2>
    <button class="sec" id="b-scan" onclick="scan()">🔍 Escanear redes</button>
    <div id="netlist"></div>
    <div id="connform" style="display:none;margin-top:12px">
      <label>Rede selecionada</label>
      <input id="f-ssid" placeholder="SSID">
      <label id="f-passlbl" style="display:block;margin-top:8px">Senha</label>
      <input id="f-pass" type="password" placeholder="senha do Wi-Fi">
      <div class="btns" style="margin-top:12px">
        <button onclick="connectUplink()">Conectar e reiniciar</button>
        <button class="sec" onclick="document.getElementById('connform').style.display='none'">Cancelar</button>
      </div>
    </div>
    <div class="hint">Ao conectar, o Pi <b>reinicia</b> (~1 min) para subir o AP no
      canal certo. O AP privado volta sozinho — reconecte-se a ele depois.</div>
  </div>

  <div class="card">
    <h2>Banda do uplink</h2>
    <div class="row"><span class="k">Atual</span><span class="v"><span id="s-band" class="pill">—</span></span></div>
    <div class="btns" style="margin-top:8px">
      <button class="sec" id="b-band-24" onclick="setBand('24')">2.4 GHz</button>
      <button class="sec" id="b-band-5" onclick="setBand('5')">5 GHz</button>
      <button class="sec" id="b-band-auto" onclick="setBand('auto')">Auto</button>
    </div>
    <div class="hint">2.4 GHz é o mais compatível. Trocar a banda <b>reinicia</b> o Pi.</div>
  </div>

  <div class="card">
    <h2>Manutenção</h2>
    <div class="btns">
      <button class="sec" onclick="doReboot()">↻ Reiniciar Pi</button>
      <button class="danger" onclick="doRollback()">⚠ Reverter (rollback)</button>
    </div>
    <div class="hint">Rollback devolve o Pi ao estado base (sem AP/rota), reconectando no Wi-Fi conhecido.</div>
  </div>
</div>
<div class="toast" id="toast"></div>

<script>
const $ = id => document.getElementById(id);
function toast(msg){ const t=$('toast'); t.textContent=msg; t.classList.add('show'); clearTimeout(t._t); t._t=setTimeout(()=>t.classList.remove('show'),3000); }
async function api(path, opts){ const r = await fetch(path, opts); return r.json(); }

async function refresh(){
  try{
    const d = await api('/api/status');
    const mode = d.mode||'—';
    const mp = $('s-mode'); mp.textContent = mode;
    mp.className = 'pill ' + (mode==='secure'?'ok':mode==='portal'?'warn':'off');
    $('s-uplink').innerHTML = d.uplink_ssid ? `${d.uplink_ssid} <span class="meta">(ch ${d.uplink_channel||'?'}, ${d.uplink_state||''})</span>` : '<span class="pill off">desconectado</span>';
    $('s-inet').innerHTML = d.internet ? '<span class="pill ok">online</span>' : '<span class="pill off">offline</span>';
    $('s-ts').innerHTML = d.tailscale_state==='Running' ? '<span class="pill ok">conectado</span>' : `<span class="pill off">${d.tailscale_state||'?'}</span>`;
    $('s-exit').textContent = d.exit_node || '—';
    $('s-clients').textContent = d.ap_clients;
    $('b-secure').className = mode==='secure' ? '' : 'sec';
    $('b-portal').className = mode==='portal' ? '' : 'sec';
    const band = d.band||'24';
    $('s-band').textContent = band==='24'?'2.4 GHz':band==='5'?'5 GHz':'Auto';
    ['24','5','auto'].forEach(b=>{ const el=$('b-band-'+b); if(el) el.className = band===b ? '' : 'sec'; });
  }catch(e){ $('st-refresh').textContent='(sem conexão)'; }
}
setInterval(refresh, 5000); refresh();

async function setMode(m){
  $('b-secure').disabled=$('b-portal').disabled=true;
  toast('Aplicando modo '+m+'…');
  const d = await api('/api/mode',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({mode:m})});
  $('b-secure').disabled=$('b-portal').disabled=false;
  toast(d.ok ? 'Modo: '+ (d.mode||m) : 'Erro: '+(d.output||''));
  refresh();
}

async function scan(){
  const b=$('b-scan'); b.disabled=true; b.innerHTML='<span class="spin"></span> Escaneando…';
  try{
    const d = await api('/api/scan');
    const list = $('netlist'); list.innerHTML='';
    (d.networks||[]).forEach(n=>{
      const el=document.createElement('div'); el.className='net';
      el.innerHTML = `<span class="name">${n.ssid}</span><span class="meta">${n.open?'🔓 aberta':'🔒'} · ${n.signal} dBm · ch ${n.channel||'?'}</span>`;
      el.onclick=()=>selectNet(n);
      list.appendChild(el);
    });
    if(!(d.networks||[]).length) list.innerHTML='<div class="hint">Nenhuma rede encontrada.</div>';
  }catch(e){ toast('Falha no scan'); }
  b.disabled=false; b.textContent='🔍 Escanear redes';
}
function selectNet(n){
  $('connform').style.display='block';
  $('f-ssid').value=n.ssid;
  $('f-pass').style.display = n.open?'none':'block';
  $('f-passlbl').style.display = n.open?'none':'block';
  $('f-pass').value='';
  $('connform').scrollIntoView({behavior:'smooth'});
}
async function connectUplink(){
  const ssid=$('f-ssid').value.trim();
  const passEl=$('f-pass');
  const open = passEl.style.display==='none';
  toast('Salvando '+ssid+'…');
  const d = await api('/api/uplink',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({ssid, open, password:passEl.value})});
  if(d.ok){ $('connform').style.display='none'; toast('Reiniciando para conectar em '+ssid+' (~1 min)…'); }
  else { toast('Erro: '+(d.error||'')); }
}
async function setBand(b){
  const label = b==='24'?'2.4 GHz':b==='5'?'5 GHz':'Auto';
  if(!confirm('Trocar a banda do uplink para '+label+'? O Pi reinicia (~1 min).'))return;
  const d = await api('/api/band',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({band:b})});
  toast(d.ok ? 'Banda '+label+' — reiniciando…' : 'Erro: '+(d.error||''));
}
async function doReboot(){ if(!confirm('Reiniciar o Pi? Você perde a conexão por ~1 min.'))return; await api('/api/reboot',{method:'POST'}); toast('Reiniciando…'); }
async function doRollback(){ if(!confirm('Reverter ao estado base? O AP e as regras serão desfeitos e o Pi reinicia.'))return; await api('/api/rollback',{method:'POST'}); toast('Revertendo…'); }
</script>
</body>
</html>
