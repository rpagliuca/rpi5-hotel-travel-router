ctrl_interface=DIR=/var/run/wpa_supplicant GROUP=netdev
update_config=1
country={{ wifi_country | default('BR') }}

# Hotel WiFi (uplink). Update SSID/PSK when you arrive.
{% if uplink_prefer_24ghz | default(true) | bool %}
# AP-sempre-de-pé com PREFERÊNCIA (não restrição): dois blocos do mesmo SSID.
# 1) prioridade alta, pinado em 2.4GHz (canais 1-13) — o AP (hw_mode=g) segue
#    qualquer canal dessa faixa sem drama.
# 2) fallback em 5GHz APENAS nos canais não-DFS (36-48, 149-165), onde o
#    hostapd PODE transmitir — o channel-sync troca o AP de banda junto.
#    Canais DFS (52-144) ficam de fora: o AP não consegue segui-los e cairia.
network={
    ssid="{{ hotel_ssid }}"
{% if hotel_open | default(false) | bool %}
    key_mgmt=NONE
{% else %}
    psk="{{ hotel_password }}"
    key_mgmt=WPA-PSK
{% endif %}
    scan_ssid=1
    priority=20
    freq_list=2412 2417 2422 2427 2432 2437 2442 2447 2452 2457 2462 2467 2472
}

network={
    ssid="{{ hotel_ssid }}"
{% if hotel_open | default(false) | bool %}
    key_mgmt=NONE
{% else %}
    psk="{{ hotel_password }}"
    key_mgmt=WPA-PSK
{% endif %}
    scan_ssid=1
    priority=10
    freq_list=5180 5200 5220 5240 5745 5765 5785 5805 5825
}
{% else %}
network={
    ssid="{{ hotel_ssid }}"
{% if hotel_open | default(false) | bool %}
    # Rede aberta (sem senha) — ex.: GTvisitor. Login e via captive portal.
    key_mgmt=NONE
{% else %}
    psk="{{ hotel_password }}"
    key_mgmt=WPA-PSK
{% endif %}
    scan_ssid=1
    priority=10
}
{% endif %}
