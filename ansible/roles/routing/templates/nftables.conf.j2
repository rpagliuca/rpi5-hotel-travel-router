#!/usr/sbin/nft -f
# ═══════════════════════════════════════════════════════════════════════════
# MODO SEGURO (padrão). Carregado no boot pelo nftables.service.
# Clientes do AP saem SOMENTE via Tailscale: uap0 → tailscale0 → exit node
# ({{ tailscale_exit_node }}) → internet. Se o Tailscale cair, os clientes
# ficam sem internet DE PROPÓSITO (Wi-Fi de hotel é não-confiável).
# Alterna para o modo portal com: `travel-router portal`
# ═══════════════════════════════════════════════════════════════════════════

flush ruleset

table inet filter {
    chain input {
        type filter hook input priority filter; policy drop;

        # Allow established/related
        ct state established,related accept

        # Allow loopback
        iifname "lo" accept

        # SSH: clientes do AP, uplink, ethernet E via Tailscale (gestão remota)
        iifname { "{{ ap_interface }}", "{{ uplink_interface }}", "{{ eth_interface }}", "tailscale0" } tcp dport 22 accept

        # Tailscale: porta de conexões diretas (senão cai só em DERP/relay)
        udp dport 41641 accept

        # Allow DHCP from AP clients
        iifname "{{ ap_interface }}" udp dport 67 accept

        # Allow DNS from AP clients
        iifname "{{ ap_interface }}" tcp dport 53 accept
        iifname "{{ ap_interface }}" udp dport 53 accept

        # Web app de configuração (http://{{ ap_ip }})
        iifname "{{ ap_interface }}" tcp dport {{ webapp_port }} accept

        # Navegadores fazem auto-upgrade para https; REJEITAR (nao dropar) a
        # 443 faz o browser falhar na hora e cair de volta pro http sozinho.
        iifname "{{ ap_interface }}" tcp dport 443 reject with tcp reset

        # Allow ICMP
        ip protocol icmp accept
        ip6 nexthdr icmpv6 accept
    }

    chain forward {
        type filter hook forward priority filter; policy drop;

        # Allow forwarding from AP clients through tailscale
        iifname "{{ ap_interface }}" oifname "tailscale0" accept

        # Allow established/related in reverse direction
        ct state established,related accept
    }

    chain output {
        type filter hook output priority filter; policy accept;
    }
}

table ip nat {
    chain postrouting {
        type nat hook postrouting priority srcnat; policy accept;

        # MASQUERADE AP client traffic going out via Tailscale exit node
        iifname "{{ ap_interface }}" oifname "tailscale0" masquerade
    }
}
