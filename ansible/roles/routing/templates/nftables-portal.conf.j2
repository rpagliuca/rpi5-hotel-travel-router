#!/usr/sbin/nft -f
# ═══════════════════════════════════════════════════════════════════════════
# MODO PORTAL (temporário). Aplicado por: `travel-router portal`
# Clientes do AP saem DIRETO pela {{ uplink_interface }} (SEM Tailscale), para
# você conseguir abrir/completar o captive portal do hotel no navegador normal
# do seu laptop/celular.
# ⚠️  INSEGURO: enquanto neste modo, o tráfego passa em claro pela rede do hotel.
# Volte para o modo seguro assim que logar: `travel-router secure`
# ═══════════════════════════════════════════════════════════════════════════

flush ruleset

table inet filter {
    chain input {
        type filter hook input priority filter; policy drop;

        ct state established,related accept
        iifname "lo" accept

        # SSH: clientes do AP, uplink, ethernet e Tailscale
        iifname { "{{ ap_interface }}", "{{ uplink_interface }}", "{{ eth_interface }}", "tailscale0" } tcp dport 22 accept
        udp dport 41641 accept

        # DHCP/DNS dos clientes do AP
        iifname "{{ ap_interface }}" udp dport 67 accept
        iifname "{{ ap_interface }}" tcp dport 53 accept
        iifname "{{ ap_interface }}" udp dport 53 accept

        # Web app de configuração (http://{{ ap_ip }})
        iifname "{{ ap_interface }}" tcp dport {{ webapp_port }} accept

        # Navegadores fazem auto-upgrade para https; REJEITAR (nao dropar) a 443
        # faz o browser falhar na hora e cair de volta pro http sozinho.
        iifname "{{ ap_interface }}" tcp dport 443 reject with tcp reset

        ip protocol icmp accept
        ip6 nexthdr icmpv6 accept
    }

    chain forward {
        type filter hook forward priority filter; policy drop;

        # Encaminha clientes do AP DIRETO pelo uplink (para o captive portal)
        iifname "{{ ap_interface }}" oifname "{{ uplink_interface }}" accept
        ct state established,related accept
    }

    chain output {
        type filter hook output priority filter; policy accept;
    }
}

table ip nat {
    chain postrouting {
        type nat hook postrouting priority srcnat; policy accept;

        # MASQUERADE dos clientes do AP saindo direto pelo uplink
        iifname "{{ ap_interface }}" oifname "{{ uplink_interface }}" masquerade
    }
}
