---
# Copy this file to inventory/group_vars/all/vault.yml and encrypt it:
#   cp vault.yml.dist inventory/group_vars/all/vault.yml
#   ansible-vault encrypt inventory/group_vars/all/vault.yml
# Add vault password to ansible/.vault_pass (never commit that file).

vault_ap_password: "CHANGE_ME_strong_wifi_password"

vault_hotel_ssid: "HotelWiFiName"
vault_hotel_password: "HotelWiFiPassword"

# Reusable Tailscale auth key (generate at https://login.tailscale.com/admin/settings/keys)
# Use a pre-auth key tagged with "tag:travel-router" for auto-approval.
vault_tailscale_authkey: "tskey-auth-XXXXXXXXXXXXXXXX"
